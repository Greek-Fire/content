{"name": "not_s390x_arch_and_system_with_kernel", "original_expression": "not_s390x_arch and system_with_kernel", "xml_content": "<ns0:platform xmlns:ns0=\"http://cpe.mitre.org/language/2.0\" id=\"not_s390x_arch_and_system_with_kernel\"><ns0:logical-test operator=\"AND\" negate=\"false\"><ns0:check-fact-ref system=\"http://oval.mitre.org/XMLSchema/oval-definitions-5\" href=\"ssg-rhel9-cpe-oval.xml\" id-ref=\"oval:ssg-proc_sys_kernel_osrelease_arch_not_s390x:def:1\" /><ns0:check-fact-ref system=\"http://oval.mitre.org/XMLSchema/oval-definitions-5\" href=\"ssg-rhel9-cpe-oval.xml\" id-ref=\"oval:ssg-system_with_kernel:def:1\" /></ns0:logical-test></ns0:platform>", "bash_conditional": "( ! ( grep -sqE \"^.*\\.s390x$\" /proc/sys/kernel/osrelease || grep -sqE \"^s390x$\" /proc/sys/kernel/arch; ) && rpm --quiet -q kernel-core )", "ansible_conditional": "( ansible_architecture != \"s390x\" and \"kernel-core\" in ansible_facts.packages )", "title": "", "definition_location": ""}