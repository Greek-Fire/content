  <oval-def:definitions>
    <oval-def:definition id="oval:ssg-selinux_all_devicefiles_labeled:def:1" version="1" class="compliance">
      <oval-def:metadata>
        <oval-def:title>Ensure No Device Files are Unlabeled by SELinux</oval-def:title>
        <oval-def:affected family="unix">
          <oval-def:platform>Red Hat Enterprise Linux 9</oval-def:platform>
        </oval-def:affected>
        <oval-def:reference ref_id="CCE-85920-7" source="CCE" />
        <oval-def:reference ref_id="selinux_all_devicefiles_labeled" source="ssg" />
        <oval-def:description>All device files in /dev should be assigned an SELinux security context other than 'device_t' and 'unlabeled_t'.</oval-def:description>
      </oval-def:metadata>
      <oval-def:criteria operator="AND">
        <oval-def:criterion comment="device_t in /dev" test_ref="oval:ssg-test_selinux_dev_device_t:tst:1" />
        <oval-def:criterion comment="unlabeled_t in /dev" test_ref="oval:ssg-test_selinux_dev_unlabeled_t:tst:1" />
      </oval-def:criteria>
    </oval-def:definition>
  </oval-def:definitions>
  <oval-def:tests>
    <linux:selinuxsecuritycontext_test id="oval:ssg-test_selinux_dev_device_t:tst:1" version="2" check="none satisfy" comment="device_t in /dev" check_existence="any_exist" state_operator="AND">
      <linux:object object_ref="oval:ssg-object_selinux_dev_device_t:obj:1" />
      <linux:state state_ref="oval:ssg-state_selinux_dev_device_t:ste:1" />
    </linux:selinuxsecuritycontext_test>
    <linux:selinuxsecuritycontext_test id="oval:ssg-test_selinux_dev_unlabeled_t:tst:1" version="2" check="none satisfy" comment="unlabeled_t in /dev" check_existence="any_exist" state_operator="AND">
      <linux:object object_ref="oval:ssg-object_selinux_dev_unlabeled_t:obj:1" />
      <linux:state state_ref="oval:ssg-state_selinux_dev_unlabeled_t:ste:1" />
    </linux:selinuxsecuritycontext_test>
  </oval-def:tests>
  <oval-def:objects>
    <unix:file_object id="oval:ssg-object_dev_device_files:obj:1" version="1" comment="device files within /dev directory">
      <unix:behaviors recurse_direction="down" />
      <unix:path operation="equals">/dev</unix:path>
      <unix:filename operation="pattern match">^.*$</unix:filename>
      <oval-def:filter action="include">oval:ssg-state_block_or_char_device_file:ste:1</oval-def:filter>
    </unix:file_object>
    <linux:selinuxsecuritycontext_object id="oval:ssg-object_selinux_dev_device_t:obj:1" version="1" comment="device_t in /dev">
      <linux:filepath operation="equals" var_ref="oval:ssg-variable_dev_device_files:var:1" var_check="at least one" />
      <oval-def:filter action="include">oval:ssg-state_selinux_dev_device_t:ste:1</oval-def:filter>
    </linux:selinuxsecuritycontext_object>
    <linux:selinuxsecuritycontext_object id="oval:ssg-object_selinux_dev_unlabeled_t:obj:1" version="1" comment="unlabeled_t in /dev">
      <linux:filepath operation="equals" var_ref="oval:ssg-variable_dev_device_files:var:1" var_check="at least one" />
      <oval-def:filter action="include">oval:ssg-state_selinux_dev_unlabeled_t:ste:1</oval-def:filter>
    </linux:selinuxsecuritycontext_object>
  </oval-def:objects>
  <oval-def:states>
    <unix:file_state id="oval:ssg-state_block_or_char_device_file:ste:1" version="1" operator="AND" comment="device files">
      <unix:type operation="pattern match">^(block|character) special$</unix:type>
    </unix:file_state>
    <linux:selinuxsecuritycontext_state id="oval:ssg-state_selinux_dev_device_t:ste:1" version="1" operator="AND" comment="device_t label">
