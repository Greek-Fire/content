          <oval-def:criterion comment="Check kernel rpm is x86_64" test_ref="oval:ssg-test_package_kernel_x64:tst:1" />
        </oval-def:criteria>
        <oval-def:criterion negate="true" comment="Check if CPU is not 64-bit" test_ref="oval:ssg-test_proc_cpuinfo_64_bit:tst:1" />
      </oval-def:criteria>
    </oval-def:definition>
