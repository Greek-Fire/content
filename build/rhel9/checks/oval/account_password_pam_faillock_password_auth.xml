  <oval-def:objects>
    <ind:textfilecontent54_object id="oval:ssg-obj_pam_faillock_password_auth_pam_unix_auth:obj:1" version="1" comment="Get all occurrences of pam_unix.so in auth section of password-auth">
      <ind:filepath operation="pattern match">^/etc/pam.d/password-auth$</ind:filepath>
      <ind:pattern operation="pattern match">^[\s]*auth\N+pam_unix\.so</ind:pattern>
      <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
