      <oval-def:metadata>
        <oval-def:title>Don't target root user in the sudoers file</oval-def:title>
        <oval-def:affected family="unix">
          <oval-def:platform>Red Hat Enterprise Linux 9</oval-def:platform>
        </oval-def:affected>
        <oval-def:reference ref_id="CCE-83531-4" source="CCE" />
