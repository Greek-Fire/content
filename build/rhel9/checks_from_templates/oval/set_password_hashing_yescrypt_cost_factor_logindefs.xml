<def-group>
  <definition class="compliance" id="set_password_hashing_yescrypt_cost_factor_logindefs" version="1">
    <metadata>
        <title>Set yescrypt Cost Factor in /etc/login.defs</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>Ensure 'YESCRYPT_COST_FACTOR' is configured with value configured through XCCDF variable var_password_yescrypt_cost_factor_login_defs' in /etc/login.defs</description>
    </metadata>
    <criteria comment="login.defs is configured correctly and configuration file exists"
    operator="AND">
    <criteria comment="login.defs is configured correctly"
    operator="OR"><criterion comment="Check the YESCRYPT_COST_FACTOR in /etc/login.defs"
  test_ref="test_set_password_hashing_yescrypt_cost_factor_logindefs" />
    </criteria><criterion comment="test if configuration file /etc/login.defs exists for set_password_hashing_yescrypt_cost_factor_logindefs" test_ref="test_set_password_hashing_yescrypt_cost_factor_logindefs_config_file_exists" />
    </criteria>
  </definition>

  
  
<external_variable comment="Variable defining the value the argument should have" datatype="int" id="var_password_yescrypt_cost_factor_login_defs" version="1" />

  

  
<ind:textfilecontent54_test check="all" check_existence="all_exist"
  comment="tests the value of YESCRYPT_COST_FACTOR setting in the /etc/login.defs file"
  id="test_set_password_hashing_yescrypt_cost_factor_logindefs" version="1">
  <ind:object object_ref="obj_set_password_hashing_yescrypt_cost_factor_logindefs" />
  <ind:state state_ref="state_set_password_hashing_yescrypt_cost_factor_logindefs" />
</ind:textfilecontent54_test>
  
<ind:textfilecontent54_object id="obj_set_password_hashing_yescrypt_cost_factor_logindefs" version="1">
  <ind:filepath>/etc/login.defs</ind:filepath>
  <ind:pattern operation="pattern match">^\s*YESCRYPT_COST_FACTOR\s*(.+?)[ \t]*(?:$|#)</ind:pattern>
  <ind:instance operation="greater than or equal" datatype="int">1</ind:instance>
</ind:textfilecontent54_object><ind:textfilecontent54_state id="state_set_password_hashing_yescrypt_cost_factor_logindefs" version="1">
  <ind:subexpression datatype="int" operation="equals" var_ref="var_password_yescrypt_cost_factor_login_defs" />
</ind:textfilecontent54_state>
  <unix:file_test id="test_set_password_hashing_yescrypt_cost_factor_logindefs_config_file_exists" check="all" check_existence="all_exist" comment="The configuration file /etc/login.defs exists for set_password_hashing_yescrypt_cost_factor_logindefs" version="1">
    <unix:object object_ref="obj_set_password_hashing_yescrypt_cost_factor_logindefs_config_file" />
  </unix:file_test>
  <unix:file_object id="obj_set_password_hashing_yescrypt_cost_factor_logindefs_config_file" comment="The configuration file /etc/login.defs for set_password_hashing_yescrypt_cost_factor_logindefs" version="1">
    <unix:filepath operation="pattern match">^/etc/login.defs</unix:filepath>
  </unix:file_object>

</def-group>