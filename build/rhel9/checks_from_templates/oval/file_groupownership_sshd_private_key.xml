<def-group>
  <definition class="compliance" id="file_groupownership_sshd_private_key" version="1">
   
      <metadata>
        <title>Verify Group Ownership on SSH Server Private *_key Key Files</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>This test makes sure that /etc/ssh/ is group owned by ssh_keys.</description>
    </metadata>
      <criteria>
    
      <criterion comment="Check file group ownership of /etc/ssh/" test_ref="test_file_groupownership_sshd_private_key_0" />
    
   
    </criteria>
  </definition>
    

      <ind:textfilecontent54_object id="object_file_groupownership_sshd_private_key_ssh_keys_gid_etc" version="1" comment="gid of the ssh_keys group (from /etc/group)">
        <ind:filepath>/etc/group</ind:filepath>
        <ind:pattern operation="pattern match">^ssh_keys:\w+:(\w+):.*</ind:pattern>
        <ind:instance datatype="int" operation="equals">1</ind:instance>
      </ind:textfilecontent54_object>

      <ind:textfilecontent54_object id="object_file_groupownership_sshd_private_key_ssh_keys_gid_usr" version="1" comment="gid of the ssh_keys group (from /usr/lib/group)">
        <ind:filepath>/usr/lib/group</ind:filepath>
        <ind:pattern operation="pattern match">^ssh_keys:\w+:(\w+):.*</ind:pattern>
        <ind:instance datatype="int" operation="equals">1</ind:instance>
      </ind:textfilecontent54_object>

  <ind:textfilecontent54_object id="object_file_groupownership_sshd_private_key_ssh_keys_gid" version="1" comment="gid of the ssh_keys group (from /etc/group or /usr/lib/group)">
    <set>
      <object_reference>object_file_groupownership_sshd_private_key_ssh_keys_gid_etc</object_reference>
      <object_reference>object_file_groupownership_sshd_private_key_ssh_keys_gid_usr</object_reference>
    </set>
  </ind:textfilecontent54_object>

      <local_variable id="var_file_groupownership_sshd_private_key_ssh_keys_gid" datatype="int" version="1" comment="Retrieve the gid of ssh_keys from either /etc/group or /usr/lib/group">
        <object_component item_field="subexpression" object_ref="object_file_groupownership_sshd_private_key_ssh_keys_gid"/>
      </local_variable>
    

  
    <unix:file_test check="all" check_existence="none_exist" comment="Testing group ownership of /etc/ssh/" id="test_file_groupownership_sshd_private_key_0" version="1">
      <unix:object object_ref="object_file_groupownership_sshd_private_key_0" />
    </unix:file_test>

    <unix:file_object comment="/etc/ssh/" id="object_file_groupownership_sshd_private_key_0" version="1">
        <unix:path>/etc/ssh</unix:path>
          <unix:filename operation="pattern match">^.*_key$</unix:filename>
      <filter action="exclude">symlink_file_groupowner</filter>
      
      <filter action="exclude">state_file_groupownership_sshd_private_key_0_ssh_keys</filter>
      
    </unix:file_object>

    
      <unix:file_state id="state_file_groupownership_sshd_private_key_0_ssh_keys" version="1">
        <unix:group_id datatype="int" operation="equals" var_ref="var_file_groupownership_sshd_private_key_ssh_keys_gid"></unix:group_id>
      </unix:file_state>
    
  
    <unix:file_state id="symlink_file_groupowner" version="1">
      <unix:type operation="equals">symbolic link</unix:type>
    </unix:file_state>
</def-group>