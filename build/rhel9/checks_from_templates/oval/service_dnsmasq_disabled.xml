<def-group><definition class="compliance" id="service_dnsmasq_disabled" version="1">
    <metadata>
        <title>Disable dnsmasq Service</title>
            <affected family="unix">
                <platform>multi_platform_all</platform>
            </affected>
        <description>The dnsmasq service should be disabled.</description>
    </metadata>
    <criteria comment="package dnsmasq removed or service dnsmasq is not configured to start" operator="OR">
      <criterion comment="dnsmasq removed" test_ref="service_dnsmasq_disabled_test_service_dnsmasq_package_dnsmasq_removed" />
      
  
      <criteria operator="OR" comment="service is not present or not configured">
        <criteria operator="AND" comment="service dnsmasq is not configured to start">
          <criterion test_ref="test_service_not_running_service_dnsmasq_disabled_dnsmasq"
            comment="dnsmasq is not running"/>
          <criterion test_ref="test_service_loadstate_is_masked_service_dnsmasq_disabled_dnsmasq"
            comment="Property LoadState of service dnsmasq is masked"/>
        </criteria>
        <criterion test_ref="test_service_not_found_service_dnsmasq_disabled_dnsmasq"
          comment="dnsmasq is not found"/>
      </criteria>

    </criteria>
  </definition>
  
  
      <linux:systemdunitproperty_test id="test_service_not_running_service_dnsmasq_disabled_dnsmasq"
        check="all" check_existence="any_exist"
        comment="Test that the dnsmasq service is not running" version="1">
        <linux:object object_ref="obj_service_not_running_service_dnsmasq_disabled_dnsmasq"/>
        <linux:state state_ref="state_service_not_running_service_dnsmasq_disabled_dnsmasq"/>
      </linux:systemdunitproperty_test>

    <linux:systemdunitproperty_object id="obj_service_not_running_service_dnsmasq_disabled_dnsmasq"
      comment="Retrieve the ActiveState property of dnsmasq" version="1">
      <linux:unit operation="pattern match">^dnsmasq\.(service|socket)$</linux:unit>
      <linux:property>ActiveState</linux:property>
    </linux:systemdunitproperty_object>

    <linux:systemdunitproperty_state id="state_service_not_running_service_dnsmasq_disabled_dnsmasq"
      version="1" comment="dnsmasq is not running">
      <linux:value operation="pattern match">inactive|failed</linux:value>
    </linux:systemdunitproperty_state>

    <linux:systemdunitproperty_test check="all" check_existence="any_exist"
      id="test_service_loadstate_is_masked_service_dnsmasq_disabled_dnsmasq"
      comment="Test that the property LoadState from the service dnsmasq is masked"
      version="1">
      <linux:object object_ref="obj_service_loadstate_is_masked_service_dnsmasq_disabled_dnsmasq"/>
      <linux:state state_ref="state_service_loadstate_is_masked_service_dnsmasq_disabled_dnsmasq"/>
    </linux:systemdunitproperty_test>

    <linux:systemdunitproperty_object  comment="Retrieve the LoadState property of dnsmasq"
      version="1" id="obj_service_loadstate_is_masked_service_dnsmasq_disabled_dnsmasq">
      <linux:unit operation="pattern match">^dnsmasq\.(service|socket)$</linux:unit>
      <linux:property>LoadState</linux:property>
    </linux:systemdunitproperty_object>

    <linux:systemdunitproperty_state comment="LoadState is set to masked"
      id="state_service_loadstate_is_masked_service_dnsmasq_disabled_dnsmasq"
      version="1">
      <linux:value>masked</linux:value>
    </linux:systemdunitproperty_state>


    <linux:systemdunitproperty_test check="all" check_existence="any_exist"
      id="test_service_not_found_service_dnsmasq_disabled_dnsmasq"
      comment="Test that the service dnsmasq is not found"
      version="1">
      <linux:object object_ref="obj_service_loadstate_is_masked_service_dnsmasq_disabled_dnsmasq"/>
      <linux:state state_ref="state_service_is_not_found_service_dnsmasq_disabled_dnsmasq"/>
    </linux:systemdunitproperty_test>

    <linux:systemdunitproperty_state comment="Service is not found"
      id="state_service_is_not_found_service_dnsmasq_disabled_dnsmasq"
      version="1">
      <linux:value>not-found</linux:value>
    </linux:systemdunitproperty_state>

  
  <linux:rpminfo_test check="all" check_existence="none_exist"
  id="service_dnsmasq_disabled_test_service_dnsmasq_package_dnsmasq_removed" version="1"
  comment="package dnsmasq is removed">
    <linux:object object_ref="obj_service_dnsmasq_disabled_test_service_dnsmasq_package_dnsmasq_removed" />
  </linux:rpminfo_test>
  <linux:rpminfo_object id="obj_service_dnsmasq_disabled_test_service_dnsmasq_package_dnsmasq_removed" version="1">
    <linux:name>dnsmasq</linux:name>
  </linux:rpminfo_object>


</def-group>