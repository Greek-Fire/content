<def-group>
  <definition class="compliance" id="file_ownership_lastlog" version="1">
  
    <metadata>
        <title>Verify Owner on lastlog Command</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>This test makes sure that /usr/bin/lastlog is owned by 0.</description>
    </metadata>
     <criteria>
   
     <criterion comment="Check file ownership of /usr/bin/lastlog" test_ref="test_file_ownership_lastlog_0" />
   
  
    </criteria>
  </definition>
  <local_variable id="var_file_ownership_lastlog_0_uid" comment="Set the uid to 0" datatype="int" version="1">
    <literal_component datatype="int">0</literal_component>
  </local_variable>

  
  <unix:file_test check="all" check_existence="none_exist" comment="Testing user ownership of /usr/bin/lastlog" id="test_file_ownership_lastlog_0" version="1">
    <unix:object object_ref="object_file_ownership_lastlog_0" />
  </unix:file_test>

  <unix:file_object comment="/usr/bin/lastlog" id="object_file_ownership_lastlog_0" version="1">
      <unix:filepath>/usr/bin/lastlog</unix:filepath>
    <filter action="exclude">symlink_file_owner</filter>
    
      <filter action="exclude">state_file_ownership_lastlog_0_0</filter>
    
  </unix:file_object>
  
    <unix:file_state id="state_file_ownership_lastlog_0_0" version="1">
      <unix:user_id datatype="int" operation="equals" var_ref="var_file_ownership_lastlog_0_uid"></unix:user_id>
    </unix:file_state>
  
  
  <unix:file_state id="symlink_file_owner" version="1">
    <unix:type operation="equals">symbolic link</unix:type>
  </unix:file_state>
</def-group>