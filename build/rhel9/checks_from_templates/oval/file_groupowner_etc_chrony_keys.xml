<def-group>
  <definition class="compliance" id="file_groupowner_etc_chrony_keys" version="1">
   
      <metadata>
        <title>Verify Group Who Owns /etc/chrony.keys File</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>This test makes sure that /etc/chrony.keys is group owned by chrony.</description>
    </metadata>
      <criteria>
    
      <criterion comment="Check file group ownership of /etc/chrony.keys" test_ref="test_file_groupowner_etc_chrony_keys_0" />
    
   
    </criteria>
  </definition>
    

      <ind:textfilecontent54_object id="object_file_groupowner_etc_chrony_keys_chrony_gid_etc" version="1" comment="gid of the chrony group (from /etc/group)">
        <ind:filepath>/etc/group</ind:filepath>
        <ind:pattern operation="pattern match">^chrony:\w+:(\w+):.*</ind:pattern>
        <ind:instance datatype="int" operation="equals">1</ind:instance>
      </ind:textfilecontent54_object>

      <ind:textfilecontent54_object id="object_file_groupowner_etc_chrony_keys_chrony_gid_usr" version="1" comment="gid of the chrony group (from /usr/lib/group)">
        <ind:filepath>/usr/lib/group</ind:filepath>
        <ind:pattern operation="pattern match">^chrony:\w+:(\w+):.*</ind:pattern>
        <ind:instance datatype="int" operation="equals">1</ind:instance>
      </ind:textfilecontent54_object>

  <ind:textfilecontent54_object id="object_file_groupowner_etc_chrony_keys_chrony_gid" version="1" comment="gid of the chrony group (from /etc/group or /usr/lib/group)">
    <set>
      <object_reference>object_file_groupowner_etc_chrony_keys_chrony_gid_etc</object_reference>
      <object_reference>object_file_groupowner_etc_chrony_keys_chrony_gid_usr</object_reference>
    </set>
  </ind:textfilecontent54_object>

      <local_variable id="var_file_groupowner_etc_chrony_keys_chrony_gid" datatype="int" version="1" comment="Retrieve the gid of chrony from either /etc/group or /usr/lib/group">
        <object_component item_field="subexpression" object_ref="object_file_groupowner_etc_chrony_keys_chrony_gid"/>
      </local_variable>
    

  
    <unix:file_test check="all" check_existence="none_exist" comment="Testing group ownership of /etc/chrony.keys" id="test_file_groupowner_etc_chrony_keys_0" version="1">
      <unix:object object_ref="object_file_groupowner_etc_chrony_keys_0" />
    </unix:file_test>

    <unix:file_object comment="/etc/chrony.keys" id="object_file_groupowner_etc_chrony_keys_0" version="1">
        <unix:filepath>/etc/chrony.keys</unix:filepath>
      <filter action="exclude">symlink_file_groupowner</filter>
      
      <filter action="exclude">state_file_groupowner_etc_chrony_keys_0_chrony</filter>
      
    </unix:file_object>

    
      <unix:file_state id="state_file_groupowner_etc_chrony_keys_0_chrony" version="1">
        <unix:group_id datatype="int" operation="equals" var_ref="var_file_groupowner_etc_chrony_keys_chrony_gid"></unix:group_id>
      </unix:file_state>
    
  
    <unix:file_state id="symlink_file_groupowner" version="1">
      <unix:type operation="equals">symbolic link</unix:type>
    </unix:file_state>
</def-group>