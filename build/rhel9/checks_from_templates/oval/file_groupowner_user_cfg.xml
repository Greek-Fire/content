<def-group>
  <definition class="compliance" id="file_groupowner_user_cfg" version="1">
   
      <metadata>
        <title>Verify /boot/grub2/user.cfg Group Ownership</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>This test makes sure that /boot/grub2/user.cfg is group owned by 0.</description>
    </metadata>
      <criteria>
    
      <criterion comment="Check file group ownership of /boot/grub2/user.cfg" test_ref="test_file_groupowner_user_cfg_0" />
    
   
    </criteria>
  </definition>
    <local_variable id="var_file_groupowner_user_cfg_0_gid" comment="Set the gid to 0" datatype="int" version="1">
      <literal_component datatype="int">0</literal_component>
    </local_variable>

  
    <unix:file_test check="all" check_existence="none_exist" comment="Testing group ownership of /boot/grub2/user.cfg" id="test_file_groupowner_user_cfg_0" version="1">
      <unix:object object_ref="object_file_groupowner_user_cfg_0" />
    </unix:file_test>

    <unix:file_object comment="/boot/grub2/user.cfg" id="object_file_groupowner_user_cfg_0" version="1">
        <unix:filepath>/boot/grub2/user.cfg</unix:filepath>
      <filter action="exclude">symlink_file_groupowner</filter>
      
      <filter action="exclude">state_file_groupowner_user_cfg_0_0</filter>
      
    </unix:file_object>

    
      <unix:file_state id="state_file_groupowner_user_cfg_0_0" version="1">
        <unix:group_id datatype="int" operation="equals" var_ref="var_file_groupowner_user_cfg_0_gid"></unix:group_id>
      </unix:file_state>
    
  
    <unix:file_state id="symlink_file_groupowner" version="1">
      <unix:type operation="equals">symbolic link</unix:type>
    </unix:file_state>
</def-group>