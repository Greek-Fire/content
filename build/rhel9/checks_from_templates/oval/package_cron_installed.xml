<def-group>
  <definition class="compliance" id="package_cron_installed"
  version="1">
    <metadata>
        <title>Install the cron service</title>
            <affected family="unix">
                <platform>multi_platform_all</platform>
            </affected>
        <description>The RPM package cronie should be installed.</description>
    </metadata>
    <criteria>
      <criterion comment="package cronie is installed"
      test_ref="test_package_cronie_installed" />
    </criteria>
  </definition>

  <linux:rpminfo_test check="all" check_existence="all_exist"
  id="test_package_cronie_installed" version="1"
  comment="package cronie is installed">
    <linux:object object_ref="obj_test_package_cronie_installed" />
    
  </linux:rpminfo_test>
  <linux:rpminfo_object id="obj_test_package_cronie_installed" version="1">
    <linux:name>cronie</linux:name>
  </linux:rpminfo_object>
  

</def-group>