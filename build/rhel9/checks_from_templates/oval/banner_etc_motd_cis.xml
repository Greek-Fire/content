<def-group>
  <definition class="compliance" id="banner_etc_motd_cis" version="1">
    <metadata>
        <title>Ensure Message Of The Day Is Configured Properly</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>Check that /etc/motd does not contain OS and version information</description>
    </metadata>
    <criteria operator="AND" comment="check">
      
      <criterion comment="Check /etc/motd does not contain OS and version information" test_ref="test_banner_etc_motd_cis" />
    </criteria>
  </definition>



  <ind:textfilecontent54_test check="all" check_existence="none_exist"
  comment="Check that the given object does not exist"
  id="test_banner_etc_motd_cis" version="1">
    <ind:object object_ref="obj_banner_etc_motd_cis" />
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_object id="obj_banner_etc_motd_cis" version="1">
    <ind:filepath>/etc/motd</ind:filepath>
    <ind:pattern operation="pattern match">(\\v|\\r|\\m|\\s|rhel9)</ind:pattern>
    <ind:instance operation="greater than or equal" datatype="int">1</ind:instance>
  </ind:textfilecontent54_object>
</def-group>