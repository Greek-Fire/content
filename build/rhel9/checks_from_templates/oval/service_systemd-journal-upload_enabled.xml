<def-group>

  <definition class="compliance" id="service_systemd-journal-upload_enabled" version="1">
    <metadata>
        <title>Enable systemd-journal-upload Service</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>The systemd-journal-upload service should be enabled if possible.</description>
    </metadata>
    <criteria comment="package systemd-journal-remote installed and service systemd-journal-upload is configured to start" operator="AND">
    <criterion comment="systemd-journal-remote installed" test_ref="test_service_systemd-journal-upload_package_systemd-journal-remote_installed" />
      <criteria comment="service systemd-journal-upload is configured to start and is running" operator="AND">
        <criterion comment="systemd-journal-upload is running" test_ref="test_service_running_systemd-journal-upload" />
        <criteria operator="OR" comment="service systemd-journal-upload is configured to start">
          <criterion comment="multi-user.target wants systemd-journal-upload" test_ref="test_multi_user_wants_systemd-journal-upload" />
          <criterion comment="multi-user.target wants systemd-journal-upload socket" test_ref="test_multi_user_wants_systemd-journal-upload_socket" />
        </criteria>
      </criteria>
    </criteria>
  </definition>

  <linux:systemdunitdependency_test check="all" check_existence="any_exist" comment="systemd test" id="test_multi_user_wants_systemd-journal-upload" version="1">
    <linux:object object_ref="object_multi_user_target_for_systemd-journal-upload_enabled" />
    <linux:state state_ref="state_systemd_systemd-journal-upload_on"/>
  </linux:systemdunitdependency_test>
  <linux:systemdunitdependency_object id="object_multi_user_target_for_systemd-journal-upload_enabled" comment="list of dependencies of multi-user.target" version="1">
    <linux:unit>multi-user.target</linux:unit>
  </linux:systemdunitdependency_object>
  <linux:systemdunitdependency_state id="state_systemd_systemd-journal-upload_on" comment="systemd-journal-upload listed at least once in the dependencies" version="1">
    <linux:dependency entity_check="at least one">systemd-journal-upload.service</linux:dependency>
  </linux:systemdunitdependency_state>

  <linux:systemdunitdependency_test check="all" check_existence="any_exist" comment="systemd test" id="test_multi_user_wants_systemd-journal-upload_socket" version="1">
    <linux:object object_ref="object_multi_user_target_for_systemd-journal-upload_socket_enabled" />
    <linux:state state_ref="state_systemd_systemd-journal-upload_socket_on"/>
  </linux:systemdunitdependency_test>
  <linux:systemdunitdependency_object id="object_multi_user_target_for_systemd-journal-upload_socket_enabled" comment="list of dependencies of multi-user.target" version="1">
    <linux:unit>multi-user.target</linux:unit>
  </linux:systemdunitdependency_object>
  <linux:systemdunitdependency_state id="state_systemd_systemd-journal-upload_socket_on" comment="systemd-journal-upload listed at least once in the dependencies" version="1">
    <linux:dependency entity_check="at least one">systemd-journal-upload.socket</linux:dependency>
  </linux:systemdunitdependency_state>

  <linux:systemdunitproperty_test id="test_service_running_systemd-journal-upload" check="at least one" check_existence="at_least_one_exists" comment="Test that the systemd-journal-upload service is running" version="1">
    <linux:object object_ref="obj_service_running_systemd-journal-upload"/>
    <linux:state state_ref="state_service_running_systemd-journal-upload"/>
  </linux:systemdunitproperty_test>
  <linux:systemdunitproperty_object id="obj_service_running_systemd-journal-upload" comment="Retrieve the ActiveState property of systemd-journal-upload" version="1">
    <linux:unit operation="pattern match">^systemd-journal-upload\.(socket|service)$</linux:unit>
    <linux:property>ActiveState</linux:property>
  </linux:systemdunitproperty_object>
  <linux:systemdunitproperty_state id="state_service_running_systemd-journal-upload" version="1" comment="systemd-journal-upload is running">
      <linux:value>active</linux:value>
  </linux:systemdunitproperty_state>



  <linux:rpminfo_test check="all" check_existence="all_exist"
  id="test_service_systemd-journal-upload_package_systemd-journal-remote_installed" version="1"
  comment="package systemd-journal-remote is installed">
    <linux:object object_ref="obj_test_service_systemd-journal-upload_package_systemd-journal-remote_installed" />
    
  </linux:rpminfo_test>
  <linux:rpminfo_object id="obj_test_service_systemd-journal-upload_package_systemd-journal-remote_installed" version="1">
    <linux:name>systemd-journal-remote</linux:name>
  </linux:rpminfo_object>
  

</def-group>