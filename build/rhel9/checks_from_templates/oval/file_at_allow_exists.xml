<def-group>
        <definition class="compliance" id="file_at_allow_exists" version="1">

        <metadata>
        <title>Ensure that /etc/at.allow exists</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>This test makes sure that/etc/at.allow does exist.</description>
    </metadata>
        <criteria>
            <criterion comment="Ensure that /etc/at.allow does exist." test_ref="test_file_at_allow_exists" />
        </criteria>
    </definition>

    <unix:file_test id="test_file_at_allow_exists" check="all" check_existence="all_exist"
