        <unix:object object_ref="object_file_at_allow_exists" />
    </unix:file_test>

    <unix:file_object comment="/etc/at.allow" id="object_file_at_allow_exists" version="1">
        <unix:filepath>/etc/at.allow</unix:filepath>
    </unix:file_object>
</def-group>