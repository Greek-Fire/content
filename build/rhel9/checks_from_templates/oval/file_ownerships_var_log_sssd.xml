<def-group>
  <definition class="compliance" id="file_ownerships_var_log_sssd" version="1">
  
    <metadata>
        <title>Verify Ownership of Files in /var/log/sssd</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>This test makes sure that /var/log/sssd/ is owned by sssd or root.</description>
    </metadata>
     <criteria>
   
     <criterion comment="Check file ownership of /var/log/sssd/" test_ref="test_file_ownerships_var_log_sssd_0" />
   
  
    </criteria>
  </definition>
  <unix:password_object id="object_file_ownerships_var_log_sssd_sssd_uid" version="1">
    <unix:username operation="equals">sssd</unix:username>
  </unix:password_object>
  <local_variable id="var_file_ownerships_var_log_sssd_sssd_uid" comment="Retrieve the uid of sssd" datatype="int" version="1">
    <object_component item_field="user_id" object_ref="object_file_ownerships_var_log_sssd_sssd_uid" />
  </local_variable>
  <unix:password_object id="object_file_ownerships_var_log_sssd_root_uid" version="1">
    <unix:username operation="equals">root</unix:username>
  </unix:password_object>
  <local_variable id="var_file_ownerships_var_log_sssd_root_uid" comment="Retrieve the uid of root" datatype="int" version="1">
    <object_component item_field="user_id" object_ref="object_file_ownerships_var_log_sssd_root_uid" />
  </local_variable>

  
  <unix:file_test check="all" check_existence="none_exist" comment="Testing user ownership of /var/log/sssd/" id="test_file_ownerships_var_log_sssd_0" version="1">
    <unix:object object_ref="object_file_ownerships_var_log_sssd_0" />
  </unix:file_test>

  <unix:file_object comment="/var/log/sssd/" id="object_file_ownerships_var_log_sssd_0" version="1">
      <unix:behaviors recurse="directories" recurse_direction="down" max_depth="-1" recurse_file_system="local" />
      <unix:path>/var/log/sssd</unix:path>
      <unix:filename operation="pattern match">.*</unix:filename>
    <filter action="exclude">symlink_file_owner</filter>
    
      <filter action="exclude">state_file_ownerships_var_log_sssd_0_sssd</filter>
    
      <filter action="exclude">state_file_ownerships_var_log_sssd_1_root</filter>
    
  </unix:file_object>
  
    <unix:file_state id="state_file_ownerships_var_log_sssd_0_sssd" version="1">
      <unix:user_id datatype="int" operation="equals" var_ref="var_file_ownerships_var_log_sssd_sssd_uid"></unix:user_id>
    </unix:file_state>
  
    <unix:file_state id="state_file_ownerships_var_log_sssd_1_root" version="1">
      <unix:user_id datatype="int" operation="equals" var_ref="var_file_ownerships_var_log_sssd_root_uid"></unix:user_id>
    </unix:file_state>
  
  
  <unix:file_state id="symlink_file_owner" version="1">
    <unix:type operation="equals">symbolic link</unix:type>
  </unix:file_state>
</def-group>