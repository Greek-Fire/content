<def-group>
  <definition class="compliance" id="file_ownerships_var_log_landscape" version="1">
  
    <metadata>
        <title>Verify Ownership of Files in /var/log/landscape</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>This test makes sure that /var/log/landscape/ is owned by root or landscape.</description>
    </metadata>
     <criteria>
   
     <criterion comment="Check file ownership of /var/log/landscape/" test_ref="test_file_ownerships_var_log_landscape_0" />
   
  
    </criteria>
  </definition>
  <unix:password_object id="object_file_ownerships_var_log_landscape_root_uid" version="1">
    <unix:username operation="equals">root</unix:username>
  </unix:password_object>
  <local_variable id="var_file_ownerships_var_log_landscape_root_uid" comment="Retrieve the uid of root" datatype="int" version="1">
    <object_component item_field="user_id" object_ref="object_file_ownerships_var_log_landscape_root_uid" />
  </local_variable>
  <unix:password_object id="object_file_ownerships_var_log_landscape_landscape_uid" version="1">
    <unix:username operation="equals">landscape</unix:username>
  </unix:password_object>
  <local_variable id="var_file_ownerships_var_log_landscape_landscape_uid" comment="Retrieve the uid of landscape" datatype="int" version="1">
    <object_component item_field="user_id" object_ref="object_file_ownerships_var_log_landscape_landscape_uid" />
  </local_variable>

  
  <unix:file_test check="all" check_existence="none_exist" comment="Testing user ownership of /var/log/landscape/" id="test_file_ownerships_var_log_landscape_0" version="1">
    <unix:object object_ref="object_file_ownerships_var_log_landscape_0" />
  </unix:file_test>

  <unix:file_object comment="/var/log/landscape/" id="object_file_ownerships_var_log_landscape_0" version="1">
      <unix:path>/var/log/landscape</unix:path>
      <unix:filename operation="pattern match">^.*$</unix:filename>
    <filter action="exclude">symlink_file_owner</filter>
    
      <filter action="exclude">state_file_ownerships_var_log_landscape_0_root</filter>
    
      <filter action="exclude">state_file_ownerships_var_log_landscape_1_landscape</filter>
    
  </unix:file_object>
  
    <unix:file_state id="state_file_ownerships_var_log_landscape_0_root" version="1">
      <unix:user_id datatype="int" operation="equals" var_ref="var_file_ownerships_var_log_landscape_root_uid"></unix:user_id>
    </unix:file_state>
  
    <unix:file_state id="state_file_ownerships_var_log_landscape_1_landscape" version="1">
      <unix:user_id datatype="int" operation="equals" var_ref="var_file_ownerships_var_log_landscape_landscape_uid"></unix:user_id>
    </unix:file_state>
  
  
  <unix:file_state id="symlink_file_owner" version="1">
    <unix:type operation="equals">symbolic link</unix:type>
  </unix:file_state>
</def-group>