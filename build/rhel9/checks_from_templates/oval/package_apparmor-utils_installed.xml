<def-group>
  <definition class="compliance" id="package_apparmor-utils_installed"
  version="1">
    <metadata>
        <title>Ensure AppArmor Utils is installed</title>
            <affected family="unix">
                <platform>multi_platform_all</platform>
            </affected>
        <description>The RPM package apparmor-utils should be installed.</description>
    </metadata>
    <criteria>
      <criterion comment="package apparmor-utils is installed"
      test_ref="test_package_apparmor-utils_installed" />
    </criteria>
  </definition>

  <linux:rpminfo_test check="all" check_existence="all_exist"
  id="test_package_apparmor-utils_installed" version="1"
  comment="package apparmor-utils is installed">
    <linux:object object_ref="obj_test_package_apparmor-utils_installed" />
    
  </linux:rpminfo_test>
  <linux:rpminfo_object id="obj_test_package_apparmor-utils_installed" version="1">
    <linux:name>apparmor-utils</linux:name>
  </linux:rpminfo_object>
  

</def-group>