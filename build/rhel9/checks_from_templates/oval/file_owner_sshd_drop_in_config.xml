<def-group>
  <definition class="compliance" id="file_owner_sshd_drop_in_config" version="1">
  
    <metadata>
        <title>Verify Owner on SSH Server Configuration Files</title>
        
    <affected family="unix">
    <platform>Red Hat Enterprise Linux 9</platform>
    </affected>
        <description>This test makes sure that /etc/ssh/sshd_config.d/ is owned by 0.</description>
    </metadata>
     <criteria>
   
     <criterion comment="Check file ownership of /etc/ssh/sshd_config.d/" test_ref="test_file_owner_sshd_drop_in_config_0" />
   
  
    </criteria>
  </definition>
  <local_variable id="var_file_owner_sshd_drop_in_config_0_uid" comment="Set the uid to 0" datatype="int" version="1">
    <literal_component datatype="int">0</literal_component>
  </local_variable>

  
  <unix:file_test check="all" check_existence="none_exist" comment="Testing user ownership of /etc/ssh/sshd_config.d/" id="test_file_owner_sshd_drop_in_config_0" version="1">
    <unix:object object_ref="object_file_owner_sshd_drop_in_config_0" />
  </unix:file_test>

  <unix:file_object comment="/etc/ssh/sshd_config.d/" id="object_file_owner_sshd_drop_in_config_0" version="1">
      <unix:path>/etc/ssh/sshd_config.d</unix:path>
      <unix:filename operation="pattern match">^.*$</unix:filename>
    <filter action="exclude">symlink_file_owner</filter>
    
      <filter action="exclude">state_file_owner_sshd_drop_in_config_0_0</filter>
    
  </unix:file_object>
  
    <unix:file_state id="state_file_owner_sshd_drop_in_config_0_0" version="1">
      <unix:user_id datatype="int" operation="equals" var_ref="var_file_owner_sshd_drop_in_config_0_uid"></unix:user_id>
    </unix:file_state>
  
  
  <unix:file_state id="symlink_file_owner" version="1">
    <unix:type operation="equals">symbolic link</unix:type>
  </unix:file_state>
</def-group>